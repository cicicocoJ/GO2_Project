<?xml version="1.0"?>
<package format="3">
  <name>go2_backend_bridge</name>
  <version>0.1.0</version>
  <description>Minimal backend bridge for Unitree GO2 EDU Jetson backend communication.</description>

  <maintainer email="unitree@example.com">unitree</maintainer>
  <license>MIT</license>

  <!-- Python ROS2 package build type -->
  <buildtool_depend>ament_python</buildtool_depend>

  <!-- Runtime dependencies -->
  <exec_depend>rclpy</exec_depend>
  <exec_depend>std_msgs</exec_depend>
  <exec_depend>unitree_go</exec_depend>

  <!-- Basic test dependencies generated by ROS2 Python packages -->
  <test_depend>ament_copyright</test_depend>
  <test_depend>ament_flake8</test_depend>
  <test_depend>ament_pep257</test_depend>
  <test_depend>python3-pytest</test_depend>

  <export>
    <build_type>ament_python</build_type>
  </export>
</package>

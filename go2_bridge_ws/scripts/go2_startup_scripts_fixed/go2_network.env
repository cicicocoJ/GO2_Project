# GO2 system network config
# 后期切换 WiFi / 手机热点时，优先只改这个文件。

# 笔记本运行 FastAPI backend 的 IP
BACKEND_IP=192.168.7.124
BACKEND_PORT=8000

# Jetson WiFi IP，用于 SSH 和 D435i 视频流访问
JETSON_USER=unitree
JETSON_IP=192.168.7.149

# 机器人 ID
ROBOT_ID=GO2_001

# Jetson 侧 MJPEG 视频流端口
JETSON_VIDEO_PORT=8081

# Jetson ROS2 workspace
JETSON_WS=/home/unitree/go2_bridge_ws

# GO2 DDS 通信网口。Jetson 和 GO2 本体通信仍然走 eth0。
GO2_DDS_IFACE=eth0

# 笔记本侧 RViz2 DDS 网口。
# 当前热点/WiFi 模式通常是 wlp2s0；旧有线模式可改成 enx00e04c36178d。
LAPTOP_DDS_IFACE=wlp2s0

LIDAR_TOPIC=/lidar_points
LIDAR_FIXED_FRAME=hesai_lidar

# GO2 system network config
# 修改网络时，优先只改这个文件

# 笔记本运行 FastAPI server 的 IP
BACKEND_IP=192.168.7.124
BACKEND_PORT=8000

# Jetson 无线网卡 IP，用于 SSH 和视频流访问
JETSON_USER=unitree
JETSON_IP=192.168.7.149

# 机器人 ID
ROBOT_ID=GO2_001

# Jetson 侧 MJPEG 视频流端口
JETSON_VIDEO_PORT=8081

# Jetson ROS2 workspace
JETSON_WS=/home/unitree/go2_bridge_ws

# GO2 DDS 通信网口。注意这里仍然是 eth0，不是 wlan0
GO2_DDS_IFACE=eth0
